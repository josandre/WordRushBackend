{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/LogDayOutput-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Jwt": {
    "Secret": "this_is_a_super_secret_key_for_jwt_2025!",
    "Issuer": "wordsRush"
  },
  "ConnectionStrings": {
    "WordRushDb": "Set in user secrets for local development"
  },
  "AllowedHosts": "*"
}
